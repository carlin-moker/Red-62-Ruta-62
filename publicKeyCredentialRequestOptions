// Función para autorizar movimiento de liquidez en Cosmicjuan.blockchain
async function autorizarMovimientoVampirio() {
    const challenge = await obtenerDesafioDelServidor(); // Generado por el contrato
    
    const options = {
        publicKey: {
            challenge: challenge,
            allowCredentials: [{
                id: credentialIdDeCarlinMoker,
                type: 'public-key'
            }],
            userVerification: "required", // Pide huella o FaceID
            timeout: 60000
        }
    };

    const assertion = await navigator.credentials.get(options);
    // Enviar 'assertion' al contrato para validación final
    await validarEnContrato(assertion);
}
